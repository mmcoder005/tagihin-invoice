---
import '@fontsource-variable/inter';
import '../styles/global.css';
import { Workspace } from '../components/Workspace';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Tagihin - Premium Invoice Generator</title>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-slate-200 print:bg-white overflow-x-hidden">
    
    <div class="absolute inset-0 z-0 bg-mesh-hero h-[800px] print:hidden pointer-events-none"></div>

    {/* Navigation */}
    <nav class="relative z-50 bg-white/60 backdrop-blur-xl border-b border-white/20 shadow-sm px-6 py-4 flex justify-between items-center print:hidden w-full sticky top-0">
      <div class="max-w-7xl mx-auto w-full flex justify-between items-center">
        <img src="/logo.png" alt="Tagihin Logo" class="h-8" />
      </div>
    </nav>

    {/* Hero Section */}
    <main class="relative z-10 max-w-7xl mx-auto px-6 py-24 text-center print:p-0 print:m-0 print:max-w-none">
      <h1 class="text-display-xxl mb-6 print:hidden text-[#20324c]">
        Buat invoice profesional<br/>dalam hitungan detik.
      </h1>
      <p class="text-lg text-slate-500 mb-12 max-w-2xl mx-auto leading-relaxed print:hidden font-light">
        Tinggalkan Excel. Mulai buat tagihan yang elegan, simpan riwayat klien otomatis, dan lacak pembayaran Anda di satu tempat yang aman.
      </p>

      {/* Embedded Live Workspace */}
      <div class="w-full max-w-[1200px] mx-auto text-left mb-32 print:m-0 print:max-w-none transform transition-transform duration-700 ease-out translate-y-0 opacity-100">
        <div class="rounded-2xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-slate-200 bg-white">
          <Workspace client:load />
        </div>
      </div>
    </main>

  </body>
</html>
